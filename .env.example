# ─────────────────────────────────────────────────────────────
# mirai-ai — environment template
# Copy to `.env` and fill in. `.env` is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────

# ── CROO Network (Provider agent) ──
# Get these from the CROO agent dashboard (https://agent.croo.network).
# The SDK key is shown ONCE on creation/rotation. Keep it ONLY here.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=
CROO_SERVICE_CONTENT_AGENT_7D_ID=
CROO_SERVICE_VOICE_IDEAS_ID=

# ── X (Twitter) API — OAuth 2.0 (PKCE) ──
# From https://developer.x.com app settings. Leave blank to use the mock adapter.
# X_MODE: "mock" (default, no cost) | "real"
X_MODE=mock
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=https://api.mirai-agent.com/oauth/x/callback

# ── Anthropic (content engine) ──
ANTHROPIC_API_KEY=
# Models: default writer + high-quality variant.
CONTENT_MODEL=claude-sonnet-4-6
CONTENT_MODEL_HQ=claude-opus-4-8

# ── Postgres ──
# Local Docker default. For Supabase, use the pooled/session or direct
# connection string from the Supabase dashboard and keep it only in .env/VPS
# secrets. Add sslmode=require when using Supabase.
DATABASE_URL=postgresql://mirai:mirai@localhost:5432/mirai?schema=public

# ── Redis (BullMQ) ──
REDIS_URL=redis://localhost:6379

# ── Token vault ──
# 32-byte hex key for AES-256-GCM encryption of stored X tokens.
# Generate with: openssl rand -hex 32
TOKEN_VAULT_KEY=

# ── Agent runtime ──
NODE_ENV=development
AGENT_EVENT_CHANNEL=mirai:events

# ── Mirai MCP licensing / entitlement ──
MIRAI_RUNTIME_MODE=hosted
MIRAI_API_URL=https://api.mirai-agent.com
# Private key stays ONLY on the Mirai provider/agent host. Public key is safe
# for local MCP verification. Generate an Ed25519 pair with your preferred key
# tooling and store PEM strings in environment/secret storage, not tracked files.
MIRAI_LICENSE_PRIVATE_KEY=
MIRAI_LICENSE_PUBLIC_KEY=
MIRAI_ENTITLEMENT_API_URL=http://localhost:8787
MIRAI_ENTITLEMENT_PORT=8787

# ── Public website ──
NEXT_PUBLIC_CROO_MARKETPLACE_URL=
NEXT_PUBLIC_MIRAI_API_URL=https://api.mirai-agent.com
NEXT_PUBLIC_NPM_PACKAGE_NAME=@mirai-agent/mcp
