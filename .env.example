# ─────────────────────────────────────────────────────────────
# mirai-ai — environment template
# Copy to `.env` and fill in. `.env` is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────

# ── CROO Network (Provider agent) ──
# Get these from the CROO agent dashboard (https://agent.croo.network).
# The SDK key is shown ONCE on creation/rotation. Keep it ONLY here.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=

# ── X (Twitter) API — OAuth 2.0 (PKCE) ──
# From https://developer.x.com app settings. Leave blank to use the mock adapter.
# X_MODE: "mock" (default, no cost) | "real"
X_MODE=mock
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=http://localhost:3000/api/x/callback

# ── Anthropic (content engine) ──
ANTHROPIC_API_KEY=
# Models: default writer + high-quality variant.
CONTENT_MODEL=claude-sonnet-4-6
CONTENT_MODEL_HQ=claude-opus-4-8

# ── Postgres ──
DATABASE_URL=postgresql://mirai:mirai@localhost:5432/mirai?schema=public

# ── Redis (BullMQ) ──
REDIS_URL=redis://localhost:6379

# ── Token vault ──
# 32-byte hex key for AES-256-GCM encryption of stored X tokens.
# Generate with: openssl rand -hex 32
TOKEN_VAULT_KEY=

# ── App ──
NODE_ENV=development
WEB_BASE_URL=http://localhost:3000
AGENT_EVENT_CHANNEL=mirai:events
