// mirai-ai data model.
//
// Identity is license-as-access, wallet-as-origin: the buyer's wallet (from the
// CROO OrderPaid event) anchors a time-boxed buyer session. MCP clients
// authenticate with the signed license issued for that order.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Identity / access ───────────────────────────

/// A time-boxed access session keyed to the buyer's wallet address.
model AccessSession {
  id              String        @id @default(cuid())
  buyerWallet     String // lowercased EVM address from the CROO order
  status          SessionStatus @default(ACTIVE)
  accessExpiresAt DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  xConnection XConnection?
  campaigns   Campaign[]
  orders      Order[]

  @@index([buyerWallet])
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

/// Encrypted X OAuth tokens (AES-256-GCM via @mirai/shared vault).
model XConnection {
  id                    String        @id @default(cuid())
  sessionId             String        @unique
  session               AccessSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  xUserId               String
  xHandle               String
  encryptedAccessToken  String
  encryptedRefreshToken String
  scope                 String
  accessTokenExpiresAt  DateTime
  tweetCount            Int           @default(0) // used to detect cold-start (empty account)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([xUserId])
}

// ─────────────────────────── Voice & content ───────────────────────────

/// Derived/edited voice profile applied to all generated & rewritten posts.
model VoiceProfile {
  id          String             @id @default(cuid())
  campaignId  String             @unique
  campaign    Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  source      VoiceProfileSource
  tone        String
  topics      String[]
  styleNotes  String[]
  doNots      String[]
  sampleVoice String             @default("")
  // Cold-start questionnaire answers (when source = QUESTIONNAIRE).
  niche       String?
  audience    String?
  goal        String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum VoiceProfileSource {
  DERIVED // from the account's existing tweets
  QUESTIONNAIRE // cold-start: built from onboarding answers
  MANUAL_OVERRIDE // user edited it through MCP/client flow
}

/// User-supplied raw content pool (USER_SUPPLIED mode).
model ContentItem {
  id           String            @id @default(cuid())
  campaignId   String
  campaign     Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  rawText      String
  status       ContentItemStatus @default(PENDING)
  usedByPostId String?
  createdAt    DateTime          @default(now())

  @@index([campaignId, status])
}

enum ContentItemStatus {
  PENDING
  USED
}

// ─────────────────────────── CROO order / campaign ───────────────────────────

/// A paid CROO order. One order = one access pass = one campaign.
model Order {
  id            String         @id @default(cuid())
  crooOrderId   String         @unique
  negotiationId String?
  buyerWallet   String
  service       String // ServiceType from @mirai/shared
  status        OrderStatus    @default(PAID)
  sessionId     String?
  session       AccessSession? @relation(fields: [sessionId], references: [id])
  campaign      Campaign?
  entitlement   Entitlement?
  deliveredAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([buyerWallet])
}

enum OrderStatus {
  PAID // OrderPaid received, work in progress
  DELIVERED // deliverOrder() called
  COMPLETED // OrderCompleted received
  FAILED
}

/// Signed access pass delivered after CROO payment and verified by local MCP.
model Entitlement {
  id            String            @id @default(cuid())
  orderId       String            @unique
  order         Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  crooOrderId   String            @unique
  buyerWallet   String
  service       String
  licenseKey    String            @unique
  issuedAt      DateTime
  expiresAt     DateTime
  scopes        String[]
  limits        Json
  status        EntitlementStatus @default(ACTIVE)
  activatedAt   DateTime?
  lastCheckedAt DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([buyerWallet])
  @@index([status, expiresAt])
}

enum EntitlementStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

/// The running content campaign for an order.
model Campaign {
  id              String         @id @default(cuid())
  orderId         String         @unique
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sessionId       String
  session         AccessSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contentMode     ContentMode    @default(AUTONOMOUS)
  enabled         Boolean        @default(true)
  status          CampaignStatus @default(WAITING_FOR_X)
  accessExpiresAt DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  voiceProfile   VoiceProfile?
  contentPolicy  ContentPolicy?
  contentItems   ContentItem[]
  scheduledPosts ScheduledPost[]
  a2aDelegations A2ADelegation[]

  @@index([status])
}

enum ContentMode {
  AUTONOMOUS
  USER_SUPPLIED
}

enum CampaignStatus {
  WAITING_FOR_X // paid, but buyer hasn't connected X yet
  ACTIVE
  PAUSED
  COMPLETED
}

/// User-defined hard/soft policy for what Mirai may post automatically.
model ContentPolicy {
  id                 String   @id @default(cuid())
  campaignId         String   @unique
  campaign           Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  allowedTopics      String[]
  blockedTopics      String[]
  blockedPhrases     String[]
  language           String   @default("any")
  toneRules          String[]
  formatRules        String[]
  requireApprovalFor String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─────────────────────────── Per-post pipeline ───────────────────────────

/// One scheduled post moving through ACQUIRE → COMPOSE → REVIEW → POST → RECORD.
model ScheduledPost {
  id             String          @id @default(cuid())
  campaignId     String
  campaign       Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  slotIndex      Int
  scheduledFor   DateTime
  angle          String? // chosen angle / brief for this slot
  stage          PostStage       @default(PLANNED)
  // ACQUIRE output (raw material, persisted so retries don't re-fetch).
  rawMaterial    String?
  // COMPOSE output.
  draftText      String?
  // POST output.
  tweetId        String?
  tweetUrl       String?
  postedAt       DateTime?
  // RECORD output.
  metrics        Json?
  failureReason  String?
  attempts       Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  a2aDelegations A2ADelegation[]

  @@unique([campaignId, slotIndex])
  @@index([campaignId, stage])
}

enum PostStage {
  PLANNED
  ACQUIRED
  COMPOSED
  REVIEWED
  POSTED
  RECORDED
  SKIPPED
  FAILED
}

// ─────────────────────────── A2A / downstream CAP orders ───────────────────────────

/// A real downstream CROO order Mirai creates as a requester while fulfilling a campaign.
model A2ADelegation {
  id                      String              @id @default(cuid())
  campaignId              String
  campaign                Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  scheduledPostId         String?
  scheduledPost           ScheduledPost?      @relation(fields: [scheduledPostId], references: [id], onDelete: SetNull)
  upstreamCrooOrderId     String
  downstreamAgent         String
  downstreamServiceId     String
  downstreamNegotiationId String?
  downstreamOrderId       String?             @unique
  status                  A2ADelegationStatus @default(NEGOTIATING)
  requestJson             Json
  responseJson            Json?
  error                   String?
  startedAt               DateTime            @default(now())
  paidAt                  DateTime?
  completedAt             DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@index([campaignId, status])
  @@index([scheduledPostId])
  @@index([downstreamServiceId])
}

enum A2ADelegationStatus {
  NEGOTIATING
  ORDER_CREATED
  PAID
  COMPLETED
  FAILED
}
