{
  "name": "@mirai/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch & node --watch --enable-source-maps dist/index.js",
    "start": "node --enable-source-maps dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@mirai/content": "workspace:*",
    "@mirai/croo": "workspace:*",
    "@mirai/db": "workspace:*",
    "@mirai/shared": "workspace:*",
    "@mirai/x": "workspace:*",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
