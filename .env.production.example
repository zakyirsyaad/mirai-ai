# ─────────────────────────────────────────────────────────────
# mirai-ai — production environment template
# Copy to your VPS secret store or an untracked `.env.production`.
# Never commit filled values.
# ─────────────────────────────────────────────────────────────

# ── CROO Network (Provider agent) ──
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=
CROO_SERVICE_CONTENT_AGENT_7D_ID=
CROO_SERVICE_VOICE_IDEAS_ID=
CROO_A2A_CREATIVE_SERVICE_ID=a8f1c20d-73f4-4551-856a-32315e18d261
CROO_A2A_CREATIVE_AGENT_NAME=Universal Workbench AI Agent

# ── X OAuth 2.0 (PKCE) ──
X_MODE=real
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=https://mirai.43-129-56-85.sslip.io/oauth/x/callback

# ── Content engine ──
ANTHROPIC_API_KEY=
CONTENT_MODEL=claude-sonnet-4-6
CONTENT_MODEL_HQ=claude-opus-4-8

# ── Supabase Postgres ──
# Recommended for a VPS that may be IPv4-only:
#   Supavisor session pooler, port 5432.
# If your VPS supports IPv6, the direct db.<project-ref>.supabase.co:5432
# connection is also fine for a persistent backend.
# Replace PASSWORD and project/region placeholders in your VPS secrets only.
#
# Direct example:
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
#
# Supavisor session pooler example:
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# ── Redis for BullMQ ──
# Supabase does not replace Redis. Use VPS Redis, Upstash, or another managed Redis.
REDIS_URL=redis://localhost:6379

# ── Token vault ──
# 32-byte hex key for AES-256-GCM encryption of stored X tokens.
# Generate with: openssl rand -hex 32
TOKEN_VAULT_KEY=

# ── Hosted agent runtime ──
NODE_ENV=production
AGENT_EVENT_CHANNEL=mirai:events
MIRAI_RUNTIME_MODE=hosted
MIRAI_API_URL=https://mirai.43-129-56-85.sslip.io
MIRAI_ENTITLEMENT_API_URL=https://mirai.43-129-56-85.sslip.io
# Must match apps/agent/deploy/nginx/mirai-agent.conf on the hosted VPS.
MIRAI_ENTITLEMENT_PORT=8797

# ── License signing ──
# Private key stays ONLY on the Mirai provider/agent host.
MIRAI_LICENSE_PRIVATE_KEY=
MIRAI_LICENSE_PUBLIC_KEY=

# ── Public website ──
NEXT_PUBLIC_CROO_MARKETPLACE_URL=
NEXT_PUBLIC_MIRAI_API_URL=https://mirai.43-129-56-85.sslip.io
NEXT_PUBLIC_NPM_PACKAGE_NAME=@mirai-agent/mcp
